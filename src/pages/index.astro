---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import SocialProof from '@/components/ui/marketing/SocialProof/SocialProof.astro';
import { TerminalDemo } from '@/components/ui/marketing/TerminalDemo';
import TechStack from '@/components/landing/TechStack.astro';
import FeatureTabs from '@/components/landing/FeatureTabs.tsx';
import LighthouseScores from '@/components/landing/LighthouseScores.astro';
import Credibility from '@/components/landing/Credibility.astro';
import CTA from '@/components/landing/CTA.astro';
---

<LandingLayout
  title="Brighton and Co"
  description="Design tokens, accessible components, SEO, and i18n configured from the first commit. Velocity ships what other starters leave as homework."
>
  <Hero layout="split" size="lg" showGrid showBlob blobPosition="right">
    <Badge slot="badge" pill pulse>B&Co v5.0 Public Beta is Live</Badge>

    <h1 slot="title">
      Welcome to <span class="text-brand-500">Brighton and Co</span>
    </h1>

    <p slot="description">
      The brand new Brighton and Co site built with Velocity.
      This site is being actively developed and improved - if you have any feedback or suggestions, please 
      <a href="/contact" class="text-brand-500 hover:underline">get in touch</a>!
    </p>

    <Fragment slot="actions">
      <Button size="lg" href="https://docs.deployvelocity.com" target="_blank">
        View Docs
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button
        size="lg"
        variant="outline"
        href="https://github.com/southwellmedia/velocity"
        target="_blank"
      >
        <Icon name="github" size="sm" />
        View on GitHub
      </Button>
    </Fragment>

    <TerminalDemo slot="aside" client:load />
  </Hero>

  <TechStack />
  <FeatureTabs client:visible />
  <LighthouseScores />
  <Credibility />
  <CTA />
</LandingLayout>
