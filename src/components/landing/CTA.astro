---
import CTASection from '@/components/ui/marketing/CTA/CTA.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Logo from '@/components/ui/marketing/Logo/Logo.astro';
---

<CTASection id="cta" variant="default" size="xl" maxWidth="lg">
  <Logo slot="logo" size="2xl" class="mx-auto" />

  <h2 slot="heading">
    Explore more of: <span class="text-brand-500">Brighton and Co</span>
  </h2>

  <p slot="description">
    Brighton and Co Version 5 - built with Velocity.
  </p>

  <Fragment slot="actions">
    <Button variant="outline" size="lg" href="https://astro.build/themes/details/velocity/" target="_blank">
      <Icon name="book" size="md" />
      Velocity
    </Button>
    <Button variant="outline" size="lg" href="https://web.brightonandco.co.uk/" target="_blank">
      <Icon name="globe" size="md" />
      Visit OLD: Brighton and Co
    </Button>
  </Fragment>
</CTASection>
