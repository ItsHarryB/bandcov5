---
import PageLayout from '@/layouts/PageLayout.astro';
import { Hero } from '@/components/hero';
import CTA from '@/components/landing/CTA.astro';
import shopLogo from '@/assets/branding/shoplogo.png';
import { ShopCarousel } from '@/components/ui/content/ShopCarousel';
import { SiVinted, SiEbay } from "react-icons/si";
import Badge from '@/components/ui/data-display/Badge/Badge.astro';

import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
// ADDED: Import your new interactive link component
import { ExternalLink } from '@/components/ui/content/ExternalLink';

// Fetch all entries from both database collections
const rawVintedItems = await getCollection('vinted');
const rawEbayItems = await getCollection('ebay');

// Filter for items that are currently active and optimize images through Astro
const vintedItems = await Promise.all(
  rawVintedItems
    .filter(item => item.data.status === 'For Sale')
    .map(async (item) => {
      const optimizedImages = await Promise.all(
        item.data.images.map(async (img) => {
          const optimized = await getImage({ src: img, format: 'webp', width: 1080, quality: 85 });
          return optimized.src;
        })
      );
      return {
        ...item.data,
        id: item.id,
        images: optimizedImages
      };
    })
);

const ebayItems = await Promise.all(
  rawEbayItems
    .filter(item => item.data.status === 'For Sale')
    .map(async (item) => {
      const optimizedImages = await Promise.all(
        item.data.images.map(async (img) => {
          const optimized = await getImage({ src: img, format: 'webp', width: 1080, quality: 85 });
          return optimized.src;
        })
      );
      return {
        ...item.data,
        id: item.id,
        images: optimizedImages
      };
    })
);
---

<PageLayout
  title="Shop"
  description="Welcome to my digital storefront. Shop pre-loved fashion and tech from Vinted and eBay."
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" pill pulse>Shop my eBay and Vinted pages</Badge>

    <h1 slot="title" class="flex flex-col items-center gap-6">
      <img 
        src={shopLogo.src} 
        alt="SHOP: B&Co Logo" 
        class="w-24 h-24 object-contain drop-shadow-md" 
      />
      <span>
        SHOP: 
        <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(135deg, #ff0055, #ff2e43);">
          B&CO
        </span>
      </span>
    </h1>

    <p slot="description">
      Welcome to my digital storefront. Whether you're hunting for pre-loved wardrobe staples or browsing for refurbished tech, choose your department below.
    </p>
  </Hero>

  <section class="py-16 bg-surface-secondary border-t border-border">
    <div class="container max-w-6xl space-y-10">
      
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 px-4 md:px-0">
        <div>
          <h2 class="text-3xl font-bold text-foreground flex items-center gap-3">
            {/* UPDATED: Replaced <a> with ExternalLink, hid the icon, kept the dialog */}
            <ExternalLink 
              href="https://vinted.co.uk/member/272494517" 
              client:load
              showIndicator={false}
              className="hover:opacity-80 transition-opacity flex items-center mt-1"
            >
              <SiVinted className="w-8 h-8" style={{ color: "#017573" }} />
            </ExternalLink>
            Vinted Highlights
          </h2>
          <p class="mt-2 text-foreground-muted">
            A selection of items from the SHOP: B&Co Vinted -
          </p>
        </div>
        {/* UPDATED: Replaced <a> with ExternalLink */}
        <ExternalLink 
          href="https://vinted.co.uk/member/272494517" 
          client:load
          showIndicator={false}
          className="text-sm font-medium hover:underline" 
          style={{ color: "#ff0055" }}
        >
          View full Vinted profile &rarr;
        </ExternalLink>
      </div>

      <ShopCarousel products={vintedItems} storeName="Vinted" client:only="react" />

    </div>
  </section>

  <section class="py-16 bg-background border-y border-border">
    <div class="container max-w-6xl space-y-10">
      
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 px-4 md:px-0">
        <div>
          <h2 class="text-3xl font-bold text-foreground flex items-center gap-3">
             {/* UPDATED: Replaced <a> with ExternalLink */}
            <ExternalLink 
              href="https://ebay.co.uk/usr/itsharryb/" 
              client:load
              showIndicator={false}
              className="hover:opacity-80 transition-opacity flex items-center mt-1"
            >
              <SiEbay className="w-10 h-10" style={{ color: "#0064D2" }} />
            </ExternalLink>
            eBay Highlights
          </h2>
          <p class="mt-2 text-foreground-muted">
            A selection of items from the SHOP: B&Co eBay -
          </p>
        </div>
        {/* UPDATED: Replaced <a> with ExternalLink */}
        <ExternalLink 
          href="https://ebay.co.uk/usr/itsharryb/" 
          client:load
          showIndicator={false}
          className="text-sm font-medium hover:underline" 
          style={{ color: "#ff0055" }}
        >
          View full eBay profile &rarr;
        </ExternalLink>
      </div>

      <ShopCarousel products={ebayItems} storeName="eBay" client:only="react" />

    </div>
  </section>

  <CTA />
</PageLayout>