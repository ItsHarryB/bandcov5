---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Input from '@/components/ui/form/Input/Input.astro';
import Textarea from '@/components/ui/form/Textarea/Textarea.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import { Hero } from '@/components/hero';
import siteConfig from '@/config/site.config';
import CTA from '@/components/landing/CTA.astro';
import Accordion from '@/components/ui/overlay/Accordion';
import Separator from '@/components/ui/layout/Separator';
import TechStack from '@/components/landing/TechStack.astro';

const webinfo = [
  {
    title: "1. What the Brighton and Co site is -",
    content: "The Brighton and Co site is my own website (Harry Brighton). I solely maintain the website in my own free time. When references are subsequently made to 'my', 'myself', 'my own', or something similar, it is referring to me, Harry Brighton. When references are subsequently made to 'website', 'site', or something similar, it is referring to new.brightonandco.co.uk and to any and all of its constituent pages, unless explicitly stated otherwise.",
    defaultOpen: true,
  },
  {
    title: "2. Using the Brighton and Co site -",
    content: "You agree to use the Brighton and Co site and all its pages for solely lawful purposes, permitted by UK law, particularly the law of England and Wales. Otherwise, as permitted by local laws. You must also use it in a way that does not infringe the rights of, or restrict or inhibit the use and enjoyment of, this site by anyone else. Your use and continued use of this website can and may likely be used to infer consent with all of the terms contained on this page. The Brighton and Co site is often updated. This means that content on this website may be changed, altered or removed with no notice.",
  },
  {
    title: "3. Services on the Brighton and Co site -",
    content: "You can use the Brighton and Co site, specifically the form located on the Contact page to send messages and enquiries to myself. The purpose behind the form is to send formal messages and enquiries, such as to request further information about something pertaining to either myself, or to the website, for example. This method of sending enquiries is managed solely by myself, using Web3Forms - which has its own terms and conditions.",
  },
  {
    title: "4. Linking to the Brighton and Co site -",
    content: "With Brighton and Co Version 5, the site has a completely refreshed look and feel, with more fluid animations. Moreover, a more comprehensive design system provides a more uniform and cohesive website design.",
  },
  {
    title: "5. More Customisation",
    content: "With the range of components available with the Velocity theme template, there are far greater options and much greater potential for future developments to Brighton and Co.",
  },
  {
    title: "6. More Content",
    content: "The potential for more content and features for the site is seemingly exponentially increased with the Velocity theme teplate. Blog posts in particular will benefit from this new design.",
  }
]
---

<PageLayout
  title="Terms and Conditions"
  description="Site Terms and Conditions"
>
  <!-- Hero Section -->
  <Hero layout="split" size="lg" showBlob>
    

    <h1 slot="title">
      Terms and Conditions
    </h1>

    <p slot="description">
      The terms and conditions for using the Brighton and Co website.
    </p>
  </Hero>
  <section class="py-20 bg-secondary">
    <div class="container">
      <h1 class="text-4xl font-bold text-foreground">Terms and Conditions</h1>
      <p class="mt-4 text-foreground-muted max-w-2xl">
        Table of Contents for site Terms and Conditions: (Coming Soon)
      </p>
    </div>
  </section>
  <section class="py-12 md:py-16">
      <div class="container max-w-3xl">
        {/* Centered this heading to match the flow of the Memoji card above it! */}
        <div class="text-center mb-10">
          <h2 class="text-3xl font-bold text-foreground">About the Site:</h2>
          <p class="text-foreground-muted mt-2">Some key details about this site.</p>
        </div>
        
        <Accordion 
         items={webinfo} 
         variant="card" 
         size="lg" 
         exclusive={true}
      />
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-16">
    <div class="container">
      <!-- Your content -->
    </div>
  </section>
  <CTA />
</PageLayout>